#Datenbank
POSTGRES_USER=appuser
POSTGRES_PASSWORD=superPassword2026
POSTGRES_DB=rechnungsanalyse
DATABASE_URL=postgresql://appuser:superPassword2026@db:5432/rechnungsanalyse

#CORS-Origins, die im Backend erlaubt sind (z.B. http://localhost:3000)
BACKEND_CORS_ORIGINS=[http://frontend:3100]

#Zeitzone für alle nutzerseitig sichtbaren Zeitstempel (Excel-Export-Spalten,
#automatische Export-Dateinamen). Container laufen intern auf UTC.
TIMEZONE=Europe/Berlin

#API-URL, die im Frontend verwendet wird.
#WICHTIG: Container-interne Docker-DNS-Adresse — das Backend lauscht INNERHALB
#des Containers immer auf Port 8000, unabhängig vom host-seitig gemappten BACKEND_PORT.
NEXT_PUBLIC_API_URL=http://backend:8000

# Pfad zum Projektordner auf dem Host.
# WICHTIG: Immer Forward-Slashes "/" verwenden — auch auf Windows!
# Backslashes "\" funktionieren in .env-Dateien nicht zuverlässig.
#
# Windows (Docker Desktop):
PROJECT_BASE_PATH=D:/Python/_Rechnungsanalyse
# Linux / Synology NAS:
#PROJECT_BASE_PATH=/volume1/docker/_rechnungsanalyse

# Absoluter Pfad des Import-Ordners INNERHALB des Containers.
# Das führende "/" sorgt dafür, dass docker-compose den richtigen Unterordner
# vom Host mountet UND das Backend einen absoluten Pfad verwendet.
# Host-Seite des Mounts: ${PROJECT_BASE_PATH}${IMPORT_BASE_PATH}
#   → Windows: D:/Python/_Rechnungsanalyse/import
#   → NAS:     /volume1/docker/_rechnungsanalyse/import
IMPORT_BASE_PATH=/import

# Absoluter Pfad des Storage-Ordners INNERHALB des Containers (gleiche Logik).
STORAGE_PATH=/storage

#Pfad zum Datenbankordner auf dem Host
DB_Path=db

#Base-Paths für Backend und Frontend
BACKEND_BASE_PATH=backend
FRONTEND_BASE_PATH=frontend

PYTHON_ENV_PATH=python_env
NODE_MODULES_PATH=node_modules

#Ports für Backend und Frontend
BACKEND_PORT=8100
FRONTEND_PORT=3100

#Worker-Konfiguration
WORKER_CONCURRENCY=4
WORKER_POLL_INTERVAL=1.0
WORKER_LOCK_TIMEOUT_MINUTES=10

#Allowed Origins für die Entwicklung
ALLOWED_DEV_ORIGINS=nas,192.168.32.4,backend